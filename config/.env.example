# ── DukOS environment ──────────────────────────────────────────────
# Copy this file to `.env` in the repo root (tools/setup.sh does this for you),
# then fill in your values. `.env` is gitignored — never commit real keys.
# Every variable below is OPTIONAL except ANTHROPIC_API_KEY, and even that can
# be blank if you are signed into a Claude subscription (see below).

# ── Required ────────────────────────────────────────────────────────
# Your Anthropic credentials. DukOS runs on Claude Code, so you can either:
#   (a) sign in to Claude Code with a Claude subscription — leave this BLANK, or
#   (b) provide an Anthropic API key here for metered pay-as-you-go billing.
ANTHROPIC_API_KEY=

# ── Agent runtime ───────────────────────────────────────────────────
# How long each agent may run per shift before it is stopped (e.g. 30m, 1h).
AGENT_TIMEOUT=30m

# ── Messaging (optional notifications) ──────────────────────────────
# Morning / evening briefings are delivered to a messaging app. Works with any
# bot that takes a token + chat id. Leave both blank to disable notifications.
MESSAGING_BOT_TOKEN=
MESSAGING_CHAT_ID=

# ── Security ────────────────────────────────────────────────────────
# Owner trust token: a long random string only you know. It gates owner-level
# overrides that might appear inside untrusted web content (see security docs).
# Generate one with:  openssl rand -hex 32
OWNER_TRUST_TOKEN=

# ── Finance (finance-research template only) ────────────────────────
# A READ-ONLY brokerage API key, used by the `portfolio-analyst` agent for
# portfolio reporting. It is never used to place trades. Leave blank if unused.
BROKERAGE_API_KEY=
# Base URL of your brokerage's read-only API (provider-specific).
BROKERAGE_API_URL=

# ── Data (optional) ─────────────────────────────────────────────────
# Connection string for a database agents may read for analytics/reporting.
DATABASE_URL=

# ── Paths (where agents look for your work) ─────────────────────────
# Absolute paths to your local folders. Leave blank to use DukOS defaults.
# Your code projects (one subfolder per project id in settings.json).
PROJECTS_DIR=
# Your game projects, if you use the game-studio template.
GAMES_DIR=
# Your downloads folder, for agents that file or process new downloads.
DOWNLOADS_DIR=
# Your screenshots folder, for agents that read screenshots as input.
SCREENSHOTS_DIR=
